      "default": "Осталось {remaining} вопросов, ~{time} мин.\n\n**Вопрос {q_num}:** {q_text}",
      "console": "",
      "telegram": "",
      "browser": ""
    },
    {
      "id": 14,
      "name": "main_questionary_complete_intro",
      "when": "Все 13 вопросов основной анкеты отвечены — заголовок.",
      "default": "Вы заполнили основную анкету!",
      "console": "",
      "telegram": "",
      "browser": ""
