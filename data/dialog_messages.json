      "default": "Выберите пункт из главного меню.",
      "console": "",
      "telegram": "",
      "browser": ""
    },
    {
      "id": 7,
      "name": "feature_stub",
      "when": "Заглушка для пунктов меню без реализованной логики.",
      "default": "Этот раздел скоро будет доступен.\n\nСледующая итерация подключит анкету и аналитику.",
      "console": "",
      "telegram": "",
      "browser": ""
    },
    {
      "id": 12,
      "name": "feature_locked",
