{
  "_description": "Тексты диалогов WVS. Пустая строка в console/telegram/browser — берётся default.",
  "messages": [
    {
      "id": 1,
      "name": "start_ask_name",
      "when": "Первый визит: streamlit/console, или Telegram без @username.",
      "default": "Как вас зовут?",
      "console": "",
      "telegram": "",
      "browser": ""
    },
    {
      "id": 2,
      "name": "empty_name",
      "when": "Пользователь отправил пустое имя.",
      "default": "Имя не может быть пустым. Как вас зовут?",
      "console": "",
      "telegram": "",
      "browser": ""
    },
    {
      "id": 3,
      "name": "main_menu_greeting",
      "when": "После регистрации или повторного визита зарегистрированного пользователя.",
      "default": "Приятно познакомиться, {user_name}!\n\nВыберите действие:",
      "console": "",
      "telegram": "",
      "browser": ""
    },
    {
      "id": 4,
      "name": "telegram_name_confirm",
      "when": "Telegram: /start при наличии @username.",
      "default": "Будем обращаться к вам как «{display}».\n\nЕсли хотите другое имя — нажмите «Изменить имя» или напишите его.",
      "console": "",
      "telegram": "",
      "browser": ""
    },
    {
      "id": 5,
      "name": "change_name_prompt",
